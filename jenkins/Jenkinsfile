pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t tetris -f docker/Dockerfile .'            }
        }
      }  

        stage('Trivy Security Scan') {
            steps {
                sh 'docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image tetris'
            }
        }

        stage('List Images') {
            steps {
                sh 'docker images'
            }
        }
    }
}
